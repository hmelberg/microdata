# Optional: server-side Anthropic API key, used only as a fallback if you want
# a shared key for some endpoints. Not required — every AI request already
# accepts the caller's own key via X-Anthropic-Key (BYOK), which is the
# expected path for this public build (no login).
# Get one at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: shared secret bypass for automation/testing. Leave unset for a
# normal deploy — with it unset, only BYOK requests succeed.
# M2PY_ACCESS_TOKEN=
